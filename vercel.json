{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/files", "destination": "/api/index.js" },
    { 
      "source": "/files/:path+", 
      "destination": "https://9odtobnujm8dodjd.public.blob.vercel-storage.com/:path+" 
    },
    { "source": "/", "destination": "/public/main-page.html" },
    { "source": "/liquid", "destination": "/public/main-page.html" },
    { "source": "/menu", "destination": "/api/index.js" },
    { "source": "/download", "destination": "/api/index.js" },
    { "source": "/dashboard", "destination": "/api/index.js" },
    { "source": "/dash", "destination": "/api/index.js" },
    { "source": "/manage", "destination": "/api/index.js" },
    { "source": "/data", "destination": "/api/index.js" },
    { "source": "/json", "destination": "/api/index.js" },
    { "source": "/syncdata", "destination": "/api/index.js" },
    { "source": "/chat", "destination": "/api/index.js" },
    { "source": "/chat/stream", "destination": "/api/index.js" },
    { "source": "/chat/send", "destination": "/api/index.js" },
    { "source": "/chat/presence", "destination": "/api/index.js" },
    { "source": "/chat-socket", "destination": "/api/index.js" },
    { "source": "/telemetry", "destination": "/api/index.js" },
    { "source": "/heartbeat", "destination": "/api/index.js" },
    { "source": "/command", "destination": "/api/index.js" },
    { "source": "/telemetry-stats", "destination": "/api/index.js" },
    { "source": "/api/telemetry", "destination": "/api/index.js" },
    { "source": "/api/heartbeat", "destination": "/api/index.js" },
    { "source": "/api/command", "destination": "/api/index.js" },
    { "source": "/api/syncdata", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/api/index.js" }
  ]
}